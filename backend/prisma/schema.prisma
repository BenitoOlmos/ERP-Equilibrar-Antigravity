generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String  @id @default(uuid())
  name         String? // Combines firstName/lastName from Profile, or User name from rfai
  email        String  @unique
  passwordHash String? // Could be called passwordHash or password, I will unify to passwordHash
  role         String  @default("CLIENT") // Enums: ADMIN, COORDINATOR, SPECIALIST, CLIENT, PATIENT
  isActive     Boolean @default(true)
  phone        String?
  meetLink     String? // For specialists/coordinators
  notes        String?
  currentWeek  Int? // From rfai

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Notification Tracking
  lastViewedRFAIAt      DateTime?
  lastViewedBitacorasAt DateTime?
  lastViewedChatAt      DateTime?

  profile Profile? // From agenda

  // Agenda Relations
  appointmentsAsClient     Appointment[]   @relation("ClientAppointments")
  appointmentsAsSpecialist Appointment[]   @relation("SpecialistAppointments")
  agendaServices           AgendaService[] @relation("ServiceSpecialist")
  payments                 Payment[]

  // Fichas Clinicas
  clinicalRecordsAsClient     ClinicalRecord[] @relation("ClientClinicalRecords")
  clinicalRecordsAsSpecialist ClinicalRecord[] @relation("SpecialistClinicalRecords")

  // RFAI Relations
  completedWeeks      UserCompletedWeek[]
  evaluations         WeeklyEvaluation[]
  audioLogs           AudioLog[]
  activityProgress    ActivityProgress[]
  bitacoraLogs        BitacoraLog[]       @relation("UserBitacoras")
  specialistBitacoras BitacoraLog[]       @relation("SpecialistBitacora")

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Cursos Relations
  progress UserProgress[]
  events   Event[]

  // CRM Relations
  diagnostics DiagnosticResult[]

  @@index([role])
  @@index([email])
}

// =======================
// AGENDA MODELS
// =======================

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName  String
  lastName   String
  documentId String? // RUT / ID number
  address    String?
  city       String?

  // For clients (Insurance)
  healthSystem           String?
  complementaryInsurance String?

  // For clients (Ficha Clinica Extensa)
  commune              String?
  birthDate            String?
  emergencyPhone       String?
  emergencyContactName String?
  observations         String?
  medicalRecordLink    String?

  // For specialists
  specialty String?
  bio       String?
  color     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgendaService {
  id          String  @id @default(uuid())
  name        String
  description String?
  duration    Int // Duration in minutes
  price       Float
  isActive    Boolean @default(true)

  branchId String? // Sede
  branch   Branch? @relation(fields: [branchId], references: [id])

  specialistId String? // Especialista
  specialist   User?   @relation("ServiceSpecialist", fields: [specialistId], references: [id])

  appointments Appointment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programs     ProgramService[]
  rfaiPrograms RFAIProgramService[]
  courses      CourseService[]
}

model Program {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Float
  isActive    Boolean @default(true)

  services ProgramService[]
  modules  Module[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  virtualAgent VirtualAgent?
}

model ProgramService {
  programId  String
  serviceId  String
  weekNumber Int    @default(1)
  count      Int    @default(1)

  program Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  service AgendaService @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([programId, serviceId, weekNumber])
}

// We unify Appointment to have fields from both, or keep them optional based on the source flow
model Appointment {
  id String @id @default(uuid())

  // Agenda fields
  clientId     String?
  client       User?          @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  specialistId String?
  specialist   User?          @relation("SpecialistAppointments", fields: [specialistId], references: [id], onDelete: Cascade)
  serviceId    String? // For Agenda Service
  service      AgendaService? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Unified Date and Time
  date    DateTime // Used by both
  timeStr String? // Original "time" from RFAI (e.g. "14:00")

  sessionType String  @default("IN_PERSON") // ONLINE, IN_PERSON
  meetLink    String?
  status      String  @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  notes       String?

  payment        Payment?
  clinicalRecord ClinicalRecord?

  // RFAI specific fields
  patientName String? // If not linked to a user
  rfaiType    String? // Original "type" from RFAI
  weekNumber  Int? // From RFAI

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([specialistId])
  @@index([clientId])
}

model Payment {
  id            String    @id @default(uuid())
  amount        Float
  concept       String? // Optional concept for manual sales
  status        String // Ej: PENDING, COMPLETED, REFUNDED
  paymentMethod String? // Ej: CASH, TRANSFER, DEBIT, CREDIT, GATEWAY
  dueDate       DateTime? // Fecha meta para Cuentas por Cobrar

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// =======================
// FINANCE MODELS (AP)
// =======================

model Supplier {
  id       String  @id @default(uuid())
  name     String
  type     String  @default("EXTERNAL") // INDIRECT_PROFESSIONAL, EMPLOYEE, UTILITY, EXTERNAL
  rut      String?
  contact  String?
  email    String?
  phone    String?
  address  String?
  isActive Boolean @default(true)

  employeeProfile   EmployeeProfile?
  honorariumProfile HonorariumProfile?

  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Expense {
  id            String    @id @default(uuid())
  amount        Float
  concept       String
  category      String // Ej: HONORARIOS, NOMINA, SERVICIOS_BASICO, INSUMOS
  status        String    @default("PENDING") // PENDING, PAID, CANCELLED
  paymentMethod String?
  dueDate       DateTime? // Fecha límite de Cuentas por Pagar
  paidAt        DateTime?

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
}

// =======================
// HR & PAYROLL MODELS
// =======================

model EmployeeProfile {
  id         String   @id @default(uuid())
  supplierId String   @unique
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  afp          String // MODELO, HABITAT, PROVIDA, CAPITAL, CUPRUM, PLANVITAL, UNO
  healthSystem String // FONASA, ISAPRE
  healthUF     Float? // UF pactada en Isapre
  cesantiaPct  Float  @default(0.6) // Seguro Cesantia (trabajador)
  mutualPct    Float  @default(0.93) // Seguro Accidentes Trabajo (empleador)

  contracts EmploymentContract[]
  payrolls  Payroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmploymentContract {
  id         String          @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  startDate  DateTime
  endDate    DateTime? // Plazo fijo o indefinido
  position   String
  baseSalary Float
  workHours  Float     @default(44)
  isActive   Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payroll {
  id         String          @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  period String // Format YYYY-MM

  // Haberes
  baseSalary    Float
  gratification Float
  bonus         Float @default(0)
  overtime      Float @default(0)
  totalHaberes  Float

  // Descuentos Legales
  afpDeduction      Float
  healthDeduction   Float
  cesantiaDeduction Float
  taxDeduction      Float // Impuesto Unico Segunda Categoria
  advances          Float @default(0) // Anticipos
  totalDeductions   Float

  netSalary Float // Alcance Liquido / Sueldo a Pagar

  ufValue  Float // Referencia de la UF usada en ese mes
  utmValue Float // Referencia de la UTM usada

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, period])
}

model HonorariumProfile {
  id         String   @id @default(uuid())
  supplierId String   @unique
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  activity    String? // Giro del profesional
  bankDetails String?

  receipts HonorariumReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HonorariumReceipt {
  id        String            @id @default(uuid())
  profileId String
  profile   HonorariumProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  receiptNumber   String? // Numero de boleta SII
  emissionDate    DateTime
  grossAmount     Float // Monto Bruto
  retentionRate   Float // e.g. 13.75
  retentionAmount Float // Monto del impuesto
  retentionType   String   @default("RETAINED_BY_COMPANY") // RETAINED_BY_PRO, RETAINED_BY_COMPANY
  netAmount       Float // Monto Liquido

  description String?
  status      String    @default("PENDING") // PENDING, PAID
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// RFAI MODELS
// =======================

model AppSettings {
  id        String   @id @default("singleton")
  key       String   @unique
  value     String // JSON string to store anything
  updatedAt DateTime @updatedAt
}

model ClinicalRecord {
  id            String       @id @default(uuid())
  clientId      String
  client        User         @relation("ClientClinicalRecords", fields: [clientId], references: [id], onDelete: Cascade)
  specialistId  String
  specialist    User         @relation("SpecialistClinicalRecords", fields: [specialistId], references: [id], onDelete: Cascade)
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  date         DateTime @default(now())
  reason       String?
  anamnesis    String?
  diagnosis    String?
  treatment    String?
  evolution    String?
  observations String?

  isSigned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([specialistId])
  @@index([date])
}

model UserCompletedWeek {
  id         String @id @default(uuid())
  userId     String
  weekNumber Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
}

model RFAIService {
  id          String  @id @default(uuid())
  profile     String  @unique
  title       String
  description String?
  price       Float   @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  virtualAgent VirtualAgent?

  evaluations WeeklyEvaluation[]
  services    RFAIProgramService[]
  modules     Module[]
}

model WeeklyEvaluation {
  id                    String   @id @default(uuid())
  userId                String
  serviceId             String
  weekNumber            Int
  timestamp             DateTime
  audioListenTime       Int?
  exerciseExecutionTime Int?
  reflectionReadCount   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service RFAIService              @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  answers WeeklyEvaluationAnswer[]
}

model WeeklyEvaluationAnswer {
  id                 String  @id @default(uuid())
  weeklyEvaluationId String
  questionText       String?
  value              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weeklyEvaluation WeeklyEvaluation @relation(fields: [weeklyEvaluationId], references: [id], onDelete: Cascade)
}

model AudioLog {
  id              String   @id @default(uuid())
  userId          String
  weekNumber      Int
  audioName       String
  durationSeconds Int
  timestamp       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityProgress {
  id              String @id @default(uuid())
  userId          String
  weekNumber      Int
  reflectionReads Int    @default(0)
  exercisePlays   Int    @default(0)
  completedDays   Int[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
}

model BitacoraLog {
  id         String   @id @default(uuid())
  userId     String
  weekNumber Int
  content    String
  timestamp  DateTime @default(now())

  // Respuestas Clínicas
  specialistId String?
  specialist   User?     @relation("SpecialistBitacora", fields: [specialistId], references: [id], onDelete: SetNull)
  response     String?
  respondedAt  DateTime?

  user User @relation("UserBitacoras", fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model DiagnosticResult {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  af             Int
  am             Int
  ae             Int
  r              Int
  ita            Int
  re             Int
  idsE           Int
  interpretation String
  profile        String
  status         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// CURSOS MODELS
// =======================

model Course {
  id          String          @id @default(uuid())
  title       String
  description String
  price       Float           @default(0)
  isActive    Boolean         @default(true)
  modules     Module[]
  progress    UserProgress[]
  services    CourseService[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  virtualAgent VirtualAgent?
}

model Module {
  id            String       @id @default(uuid())
  courseId      String?
  course        Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  programId     String?
  program       Program?     @relation(fields: [programId], references: [id], onDelete: Cascade)
  rfaiServiceId String?
  rfaiService   RFAIService? @relation(fields: [rfaiServiceId], references: [id], onDelete: Cascade)
  title         String
  type          String // VIDEO, AUDIO, TEXT, PDF, IMAGE, QUESTIONNAIRE
  duration      Int? // in seconds
  contentUrl    String?
  description   String?
  questions     Json? // Store questions for bitacora/evaluation
  order         Int
  weekNumber    Int          @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model UserProgress {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedModules String[] // Array of module IDs
  audioTracking    Json? // Store audio progress
  bitacoras        Json? // Store bitacora answers
  evaluations      Json? // Store evaluation scores and answers
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, courseId])
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType String
  data      Json?
  timestamp DateTime @default(now())
}

// =======================
// PHASE 4: Relational Matrices
// =======================

model RFAIProgramService {
  rfaiServiceId   String
  agendaServiceId String
  weekNumber      Int    @default(1)
  count           Int    @default(1)

  rfaiService   RFAIService   @relation(fields: [rfaiServiceId], references: [id], onDelete: Cascade)
  agendaService AgendaService @relation(fields: [agendaServiceId], references: [id], onDelete: Cascade)

  @@id([rfaiServiceId, agendaServiceId, weekNumber])
}

model CourseService {
  courseId        String
  agendaServiceId String
  weekNumber      Int    @default(1)
  count           Int    @default(1)

  course        Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  agendaService AgendaService @relation(fields: [agendaServiceId], references: [id], onDelete: Cascade)

  @@id([courseId, agendaServiceId, weekNumber])
}

// =======================
// INVENTORY MODELS
// =======================

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments Payment[]
}

// =======================
// SYSTEM CONFIGURATION
// =======================

model Branch {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("PHYSICAL") // "PHYSICAL" | "VIRTUAL"
  address     String?
  contactName String?
  phone       String?
  meetLink    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services AgendaService[]
}

// =======================
// MASS MAILING (MARKETING)
// =======================

model MailingContact {
  id       String         @id @default(uuid())
  email    String         @unique
  name     String?
  source   String?        @default("IMPORTED") // "IMPORTED", "SYSTEM"
  isActive Boolean        @default(true)
  groups   MailingGroup[] @relation("ContactGroups")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailingGroup {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  color       String?          @default("bg-indigo-50 text-indigo-600")
  contacts    MailingContact[] @relation("ContactGroups")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MailingTemplate {
  id          String  @id @default(uuid())
  title       String
  description String?
  subject     String
  content     String
  iconName    String? @default("PenTool")
  colorClass  String? @default("bg-slate-50 text-slate-600")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// VIRTUAL AGENT (VERTEX AI)
// =======================

model VirtualAgent {
  id              String   @id @default(uuid())
  systemPrompt    String   
  welcomeMessage  String?  
  isActive        Boolean  @default(true)
  
  programId       String?  @unique
  program         Program? @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  courseId        String?  @unique
  course          Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  rfaiServiceId   String?  @unique
  rfaiService     RFAIService? @relation(fields: [rfaiServiceId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// =======================
// WHATSAPP META (AI CRM HUB)
// =======================

model WhatsAppLead {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  email           String?
  isapre          String?
  requestedHours  String?
  postSalesNeed   String?
  status          String   @default("BOT") // "BOT" (IA Activa) | "HUMAN" (Coordinadora Manual) | "RESOLVED"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  messages        WhatsAppMessage[]
}

model WhatsAppMessage {
  id         String       @id @default(uuid())
  leadId     String
  lead       WhatsAppLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content    String
  sender     String       // "USER", "BOT", "ADMIN"
  createdAt  DateTime     @default(now())
}
